<?xml version="1.0" encoding="UTF-8"?>
<manifest xmlns="http://www.tableau.com/xml/extension_manifest" manifest-version="1.0">
  <dashboard-extension id="com.eimis.voicecontrol" extension-version="1.0.0">

    <default-locale>en_US</default-locale>
    <name>Voice Control Extension</name>
    <description>Control Tableau dashboards using voice or text commands.</description>

    <author
      name="Eimis Pacheco"
      email="eimispacheco@gmail.com"
      organization="Hackathon"
      website="https://digit-nav-goal-herbal.trycloudflare.com/" />

    <min-api-version>1.0</min-api-version>

    <source-location>
      <url>https://digit-nav-goal-herbal.trycloudflare.com/index.html</url>
    </source-location>

    <icon></icon>

    <permissions>
      <permission>full data</permission>
    </permissions>

  </dashboard-extension>
</manifest>